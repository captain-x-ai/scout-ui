# REST API base URL (scout-backend). Required for Google OAuth redirect.
# Local dev: copy to .env and point at your backend.
VITE_API_BASE_URL=http://localhost:8080

# Docker production: pass the same variable at container runtime (not only at build time).
# Example:
#   docker build -t scout-ui ./scout-ui
#   docker run -p 3000:8080 -e VITE_API_BASE_URL=https://api.example.com scout-ui
